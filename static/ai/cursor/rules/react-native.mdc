# Lumina React Native Patterns

All `@startsoft/lumina` hooks work identically in React Native. The core API is the same -- only the UI layer and platform-specific APIs differ.

## Imports

Use React Native components instead of HTML elements:

```typescript
import { View, Text, TouchableOpacity, FlatList, TextInput, Alert, ActivityIndicator } from 'react-native';
import {
  useModelIndex,
  useModelShow,
  useModelStore,
  useModelUpdate,
  useModelDelete,
  useAuth,
  useOrganization,
  configureApi,
  AuthProvider,
} from '@startsoft/lumina';
```

## Storage: AsyncStorage Instead of localStorage

Use `AsyncStorage` for token persistence. Configure this in the API setup:

```typescript
import AsyncStorage from '@react-native-async-storage/async-storage';
import { configureApi } from '@startsoft/lumina';

configureApi({
  baseURL: 'https://api.example.com',
  storage: AsyncStorage, // Use AsyncStorage instead of localStorage
  onUnauthorized: () => {
    // Navigate to login screen using your navigation library
    navigationRef.navigate('Login');
  },
});
```

## List View with FlatList

Use `FlatList` instead of `.map()` for rendering lists:

```tsx
import { View, Text, FlatList, ActivityIndicator, TouchableOpacity } from 'react-native';
import { useModelIndex } from '@startsoft/lumina';

interface Article {
  id: number;
  title: string;
  status: string;
  created_at: string;
}

function ArticleListScreen() {
  const { data, isLoading, error, refetch } = useModelIndex<Article>('articles', {
    includes: ['author'],
    sort: '-created_at',
    perPage: 20,
  });

  if (isLoading) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <ActivityIndicator size="large" />
      </View>
    );
  }

  if (error) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <Text>Error: {error.message}</Text>
        <TouchableOpacity onPress={() => refetch()}>
          <Text>Retry</Text>
        </TouchableOpacity>
      </View>
    );
  }

  return (
    <FlatList
      data={data.data}
      keyExtractor={(item) => item.id.toString()}
      renderItem={({ item }) => (
        <TouchableOpacity
          style={{ padding: 16, borderBottomWidth: 1, borderBottomColor: '#eee' }}
          onPress={() => navigation.navigate('ArticleDetail', { id: item.id })}
        >
          <Text style={{ fontSize: 18, fontWeight: 'bold' }}>{item.title}</Text>
          <Text style={{ color: '#666' }}>{item.status}</Text>
        </TouchableOpacity>
      )}
      onRefresh={() => refetch()}
      refreshing={isLoading}
    />
  );
}
```

## Detail View

```tsx
import { View, Text, ActivityIndicator, ScrollView } from 'react-native';
import { useModelShow } from '@startsoft/lumina';

function ArticleDetailScreen({ route }: { route: { params: { id: number } } }) {
  const { data: article, isLoading, error } = useModelShow<Article>('articles', route.params.id, {
    includes: ['author', 'comments'],
  });

  if (isLoading) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <ActivityIndicator size="large" />
      </View>
    );
  }

  if (error) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <Text>Error: {error.message}</Text>
      </View>
    );
  }

  return (
    <ScrollView style={{ padding: 16 }}>
      <Text style={{ fontSize: 24, fontWeight: 'bold' }}>{article.title}</Text>
      <Text style={{ color: '#666', marginVertical: 8 }}>By {article.author?.name}</Text>
      <Text>{article.body}</Text>
    </ScrollView>
  );
}
```

## Forms with TextInput

```tsx
import { View, Text, TextInput, TouchableOpacity, ActivityIndicator, Alert } from 'react-native';
import { useModelStore } from '@startsoft/lumina';
import { useState } from 'react';

function CreateArticleScreen() {
  const { mutate, isPending, error } = useModelStore<Article>('articles');
  const [title, setTitle] = useState('');
  const [body, setBody] = useState('');

  const handleCreate = () => {
    mutate(
      { title, body, status: 'draft' },
      {
        onSuccess: (article) => {
          Alert.alert('Success', 'Article created successfully');
          navigation.goBack();
        },
        onError: (err) => {
          Alert.alert('Error', err.message);
        },
      }
    );
  };

  return (
    <View style={{ padding: 16 }}>
      <Text style={{ fontSize: 16, marginBottom: 4 }}>Title</Text>
      <TextInput
        value={title}
        onChangeText={setTitle}
        placeholder="Article title"
        style={{
          borderWidth: 1,
          borderColor: '#ccc',
          borderRadius: 8,
          padding: 12,
          marginBottom: 16,
        }}
      />

      <Text style={{ fontSize: 16, marginBottom: 4 }}>Body</Text>
      <TextInput
        value={body}
        onChangeText={setBody}
        placeholder="Article body"
        multiline
        numberOfLines={6}
        style={{
          borderWidth: 1,
          borderColor: '#ccc',
          borderRadius: 8,
          padding: 12,
          marginBottom: 16,
          textAlignVertical: 'top',
        }}
      />

      {error?.status === 422 && error.errors && (
        <View style={{ marginBottom: 16 }}>
          {Object.entries(error.errors).map(([field, messages]) => (
            <Text key={field} style={{ color: 'red' }}>
              {field}: {(messages as string[]).join(', ')}
            </Text>
          ))}
        </View>
      )}

      <TouchableOpacity
        onPress={handleCreate}
        disabled={isPending}
        style={{
          backgroundColor: isPending ? '#ccc' : '#007AFF',
          padding: 16,
          borderRadius: 8,
          alignItems: 'center',
        }}
      >
        {isPending ? (
          <ActivityIndicator color="#fff" />
        ) : (
          <Text style={{ color: '#fff', fontWeight: 'bold' }}>Create Article</Text>
        )}
      </TouchableOpacity>
    </View>
  );
}
```

## Delete Confirmation with Alert.alert

Use `Alert.alert` instead of `window.confirm`:

```tsx
import { Alert } from 'react-native';
import { useModelDelete } from '@startsoft/lumina';

function DeleteArticleButton({ articleId }: { articleId: number }) {
  const { mutate, isPending } = useModelDelete('articles');

  const handleDelete = () => {
    Alert.alert(
      'Delete Article',
      'Are you sure you want to delete this article?',
      [
        { text: 'Cancel', style: 'cancel' },
        {
          text: 'Delete',
          style: 'destructive',
          onPress: () => {
            mutate(articleId, {
              onSuccess: () => {
                Alert.alert('Success', 'Article deleted');
                navigation.goBack();
              },
              onError: (err) => {
                Alert.alert('Error', err.message);
              },
            });
          },
        },
      ]
    );
  };

  return (
    <TouchableOpacity
      onPress={handleDelete}
      disabled={isPending}
      style={{
        backgroundColor: '#FF3B30',
        padding: 12,
        borderRadius: 8,
        alignItems: 'center',
      }}
    >
      {isPending ? (
        <ActivityIndicator color="#fff" />
      ) : (
        <Text style={{ color: '#fff', fontWeight: 'bold' }}>Delete</Text>
      )}
    </TouchableOpacity>
  );
}
```

## Login Screen

```tsx
import { View, Text, TextInput, TouchableOpacity, ActivityIndicator, Alert } from 'react-native';
import { useAuth } from '@startsoft/lumina';
import { useState } from 'react';

function LoginScreen() {
  const { login, isAuthenticated } = useAuth();
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [isLoading, setIsLoading] = useState(false);

  const handleLogin = async () => {
    setIsLoading(true);
    try {
      await login(email, password);
      // Navigation happens automatically via auth state change
    } catch (err: any) {
      Alert.alert('Login Failed', err.message || 'Invalid credentials');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <View style={{ flex: 1, justifyContent: 'center', padding: 24 }}>
      <Text style={{ fontSize: 28, fontWeight: 'bold', marginBottom: 32, textAlign: 'center' }}>
        Sign In
      </Text>

      <TextInput
        value={email}
        onChangeText={setEmail}
        placeholder="Email"
        keyboardType="email-address"
        autoCapitalize="none"
        style={{
          borderWidth: 1,
          borderColor: '#ccc',
          borderRadius: 8,
          padding: 12,
          marginBottom: 16,
        }}
      />

      <TextInput
        value={password}
        onChangeText={setPassword}
        placeholder="Password"
        secureTextEntry
        style={{
          borderWidth: 1,
          borderColor: '#ccc',
          borderRadius: 8,
          padding: 12,
          marginBottom: 24,
        }}
      />

      <TouchableOpacity
        onPress={handleLogin}
        disabled={isLoading}
        style={{
          backgroundColor: isLoading ? '#ccc' : '#007AFF',
          padding: 16,
          borderRadius: 8,
          alignItems: 'center',
        }}
      >
        {isLoading ? (
          <ActivityIndicator color="#fff" />
        ) : (
          <Text style={{ color: '#fff', fontWeight: 'bold', fontSize: 16 }}>Sign In</Text>
        )}
      </TouchableOpacity>
    </View>
  );
}
```

## Navigation Patterns

Use React Navigation with Lumina's auth state for conditional navigation:

```tsx
import { NavigationContainer } from '@react-navigation/native';
import { createNativeStackNavigator } from '@react-navigation/native-stack';
import { useAuth, AuthProvider } from '@startsoft/lumina';

const Stack = createNativeStackNavigator();

function AppNavigator() {
  const { isAuthenticated } = useAuth();

  return (
    <NavigationContainer>
      <Stack.Navigator>
        {isAuthenticated ? (
          <>
            <Stack.Screen name="ArticleList" component={ArticleListScreen} />
            <Stack.Screen name="ArticleDetail" component={ArticleDetailScreen} />
            <Stack.Screen name="CreateArticle" component={CreateArticleScreen} />
          </>
        ) : (
          <Stack.Screen
            name="Login"
            component={LoginScreen}
            options={{ headerShown: false }}
          />
        )}
      </Stack.Navigator>
    </NavigationContainer>
  );
}

function App() {
  return (
    <AuthProvider>
      <AppNavigator />
    </AuthProvider>
  );
}
```

## DON'Ts

- **DO NOT** use `window.confirm()` or `window.alert()`. These are browser APIs. Use `Alert.alert()` from React Native instead.

```typescript
// BAD
if (window.confirm('Delete?')) { ... }

// GOOD
Alert.alert('Confirm', 'Delete?', [
  { text: 'Cancel', style: 'cancel' },
  { text: 'Delete', style: 'destructive', onPress: () => { ... } },
]);
```

- **DO NOT** use HTML elements (`<div>`, `<span>`, `<button>`, `<input>`, `<form>`, `<p>`, `<h1>`, etc.). Use React Native components instead.

```tsx
// BAD
<div><h1>Title</h1><p>Body</p></div>

// GOOD
<View><Text style={{ fontSize: 24 }}>Title</Text><Text>Body</Text></View>
```

- **DO NOT** use `localStorage` or `sessionStorage`. Use `AsyncStorage` from `@react-native-async-storage/async-storage`.

- **DO NOT** use CSS classes or stylesheets. Use React Native's `StyleSheet.create()` or inline style objects.

- **DO NOT** use `<form>` with `onSubmit`. React Native has no form element. Handle submission with `TouchableOpacity` or `Pressable` `onPress` handlers.

- **DO NOT** forget that all `@startsoft/lumina` hooks work identically in React Native. The only differences are in the UI layer and platform APIs.
