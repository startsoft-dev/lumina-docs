# Lumina React Authentication Patterns

All authentication utilities are imported from `@startsoft/lumina`.

## API Configuration

Configure the Lumina client before rendering the app:

```typescript
import { configureApi } from '@startsoft/lumina';

configureApi({
  baseURL: 'https://api.example.com',
  onUnauthorized: () => {
    // Called when a 401 response is received
    // Redirect to login or clear auth state
    window.location.href = '/login';
  },
});
```

## AuthProvider

Wrap your application with `AuthProvider` to make authentication state available throughout the component tree:

```tsx
import { AuthProvider } from '@startsoft/lumina';

function App() {
  return (
    <AuthProvider>
      <Router>
        <Routes />
      </Router>
    </AuthProvider>
  );
}
```

## useAuth Hook

The `useAuth` hook provides authentication state and actions:

```typescript
import { useAuth } from '@startsoft/lumina';

const {
  token,             // string | null -- current auth token
  isAuthenticated,   // boolean -- whether the user is logged in
  login,             // (email: string, password: string) => Promise<void>
  logout,            // () => Promise<void>
  setOrganization,   // (orgIdentifier: string) => void
} = useAuth();
```

## Login Flow

```tsx
import { useState } from 'react';
import { useAuth } from '@startsoft/lumina';

function LoginPage() {
  const { login, isAuthenticated } = useAuth();
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [error, setError] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(false);

  if (isAuthenticated) {
    return <Navigate to="/dashboard" />;
  }

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setError(null);
    setIsLoading(true);

    try {
      await login(email, password);
      // On success, isAuthenticated becomes true and triggers redirect
    } catch (err: any) {
      setError(err.message || 'Invalid credentials');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <form onSubmit={handleSubmit}>
      <input
        type="email"
        value={email}
        onChange={(e) => setEmail(e.target.value)}
        placeholder="Email"
        required
      />
      <input
        type="password"
        value={password}
        onChange={(e) => setPassword(e.target.value)}
        placeholder="Password"
        required
      />
      <button type="submit" disabled={isLoading}>
        {isLoading ? 'Signing in...' : 'Sign In'}
      </button>
      {error && <p>{error}</p>}
    </form>
  );
}
```

## Logout Flow

```tsx
import { useAuth } from '@startsoft/lumina';

function LogoutButton() {
  const { logout } = useAuth();
  const [isLoading, setIsLoading] = useState(false);

  const handleLogout = async () => {
    setIsLoading(true);
    try {
      await logout();
      // Token is cleared, isAuthenticated becomes false
      window.location.href = '/login';
    } catch (err) {
      console.error('Logout failed:', err);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <button onClick={handleLogout} disabled={isLoading}>
      {isLoading ? 'Signing out...' : 'Sign Out'}
    </button>
  );
}
```

## useOrganization Hook

Access the currently selected organization:

```typescript
import { useOrganization } from '@startsoft/lumina';

const {
  organization,  // Organization | null -- current organization object
  isLoading,     // boolean
} = useOrganization();
```

Usage example:

```tsx
function DashboardHeader() {
  const { organization, isLoading } = useOrganization();

  if (isLoading) return <div>Loading...</div>;
  if (!organization) return <div>No organization selected</div>;

  return (
    <header>
      <h1>{organization.name}</h1>
      <p>Slug: {organization.slug}</p>
    </header>
  );
}
```

## Organization Switching

Use `setOrganization` from `useAuth` to switch the active organization context:

```tsx
import { useAuth } from '@startsoft/lumina';

function OrganizationSwitcher({ organizations }: { organizations: Organization[] }) {
  const { setOrganization } = useAuth();

  return (
    <select onChange={(e) => setOrganization(e.target.value)}>
      {organizations.map((org) => (
        <option key={org.id} value={org.slug}>
          {org.name}
        </option>
      ))}
    </select>
  );
}
```

## useOwner Hook

Fetch organization data with optional includes:

```typescript
import { useOwner } from '@startsoft/lumina';

const { data: organization, isLoading, error } = useOwner({
  includes: ['members', 'subscription', 'settings'],
});
```

Usage example:

```tsx
function OrganizationMembers() {
  const { data: org, isLoading } = useOwner({
    includes: ['members'],
  });

  if (isLoading) return <div>Loading...</div>;

  return (
    <div>
      <h2>Members of {org.name}</h2>
      <ul>
        {org.members?.map((member: User) => (
          <li key={member.id}>{member.name} - {member.email}</li>
        ))}
      </ul>
    </div>
  );
}
```

## useOrganizationExists Hook

Check if an organization slug is available (useful during registration or org creation):

```typescript
import { useOrganizationExists } from '@startsoft/lumina';

const { exists, isLoading } = useOrganizationExists('acme-corp');
```

Usage example:

```tsx
function OrganizationSlugInput() {
  const [slug, setSlug] = useState('');
  const { exists, isLoading } = useOrganizationExists(slug);

  return (
    <div>
      <input
        value={slug}
        onChange={(e) => setSlug(e.target.value)}
        placeholder="Organization slug"
      />
      {isLoading && <span>Checking availability...</span>}
      {!isLoading && slug && (
        <span>{exists ? 'Slug is taken' : 'Slug is available'}</span>
      )}
    </div>
  );
}
```

## Protected Routes Pattern

```tsx
import { useAuth } from '@startsoft/lumina';

function ProtectedRoute({ children }: { children: React.ReactNode }) {
  const { isAuthenticated } = useAuth();

  if (!isAuthenticated) {
    return <Navigate to="/login" replace />;
  }

  return <>{children}</>;
}

// Usage
function AppRoutes() {
  return (
    <Routes>
      <Route path="/login" element={<LoginPage />} />
      <Route
        path="/dashboard/*"
        element={
          <ProtectedRoute>
            <Dashboard />
          </ProtectedRoute>
        }
      />
    </Routes>
  );
}
```

## DON'Ts

- **DO NOT** store the auth token manually in localStorage or cookies. The `AuthProvider` handles token persistence automatically.
- **DO NOT** add Authorization headers manually to requests. The Lumina client injects the token into all API requests automatically.
- **DO NOT** call API endpoints directly for login/logout. Always use the `login()` and `logout()` methods from `useAuth()`.
- **DO NOT** access `useAuth()` outside of the `AuthProvider` tree. Ensure `AuthProvider` wraps all components that need authentication state.
